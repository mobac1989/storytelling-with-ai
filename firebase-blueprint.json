{
  "entities": {
    "lead": {
      "title": "Lead",
      "description": "A lead from the storytelling course registration form",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the lead"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email of the lead"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the lead"
        },
        "message": {
          "type": "string",
          "description": "The message from the lead"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the lead was created"
        }
      },
      "required": ["name", "email", "createdAt"]
    }
  },
  "firestore": {
    "leads": {
      "schema": "lead",
      "description": "Collection of leads from the registration form"
    }
  }
}
